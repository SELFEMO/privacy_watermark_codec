{
  "name": "privacy-watermark-codec",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "node scripts/preflight-tauri.mjs && npm run ffmpeg:manifest && npm run tauri -- dev",
    "tauri:build": "node scripts/build-release.mjs",
    "tauri:build:x64": "node scripts/build-release.mjs --arch x64",
    "tauri:build:amd64": "node scripts/build-release.mjs --arch amd64",
    "tauri:build:arm64": "node scripts/build-release.mjs --arch arm64",
    "tauri:build:msi": "node scripts/build-release.mjs msi",
    "tauri:build:nsis": "node scripts/build-release.mjs nsis",
    "ffmpeg:manifest": "node scripts/generate-ffmpeg-manifest.mjs",
    "ffmpeg:manifest:strict": "node scripts/generate-ffmpeg-manifest.mjs --strict",
    "tauri:build:windows:nsis": "node scripts/build-release.mjs nsis",
    "tauri:build:windows:x64": "node scripts/build-release.mjs nsis --arch x64",
    "tauri:build:windows:amd64": "node scripts/build-release.mjs nsis --arch amd64",
    "tauri:build:windows:msi": "node scripts/build-release.mjs msi",
    "tauri:build:macos": "node scripts/build-release.mjs app",
    "tauri:build:macos:amd64": "node scripts/build-release.mjs app --target x86_64-apple-darwin",
    "tauri:build:macos:x64": "node scripts/build-release.mjs app --target x86_64-apple-darwin",
    "tauri:build:macos:arm64": "node scripts/build-release.mjs app --target aarch64-apple-darwin",
    "tauri:build:linux": "node scripts/build-release.mjs appimage,deb",
    "tauri:build:linux:x64": "node scripts/build-release.mjs appimage,deb --target x86_64-unknown-linux-gnu",
    "tauri:build:linux:amd64": "node scripts/build-release.mjs appimage,deb --target x86_64-unknown-linux-gnu",
    "tauri:build:macos:dmg": "node scripts/build-release.mjs app,dmg",
    "tauri:build:macos:amd64:dmg": "node scripts/build-release.mjs app,dmg --target x86_64-apple-darwin",
    "tauri:build:macos:x64:dmg": "node scripts/build-release.mjs app,dmg --target x86_64-apple-darwin",
    "tauri:build:macos:arm64:dmg": "node scripts/build-release.mjs app,dmg --target aarch64-apple-darwin"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vue-tsc": "^3.0.0"
  }
}
