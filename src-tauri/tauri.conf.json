{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Privacy Watermark Codec",
  "version": "0.1.0",
  "identifier": "com.privacywatermark.codec",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "图隐私水印编解码器",
        "url": "index.html",
        "width": 1440,
        "height": 960,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": true,
        "create": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    },
    "enableGTKAppId": true
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "category": "Utility",
    "shortDescription": "Local image and video invisible privacy watermark encoder/decoder",
    "longDescription": "A local-first desktop app for encrypted frequency-domain privacy watermarks and perceptual tamper detection.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./windows/installer-hooks.nsh",
        "languages": [
          "English",
          "SimpChinese"
        ],
        "displayLanguageSelector": true,
        "compression": "zlib"
      }
    },
    "resources": [
      "vendor/ffmpeg/manifest.json",
      "vendor/ffmpeg/LICENSE.txt",
      "vendor/ffmpeg/README.md",
      "vendor/ffmpeg/VERSION.txt",
      "vendor/ffmpeg/windows_x64/*",
      "vendor/ffmpeg/windows_arm64/*",
      "vendor/ffmpeg/macos_x64/*",
      "vendor/ffmpeg/macos_amd64/*",
      "vendor/ffmpeg/macos_arm64/*",
      "vendor/ffmpeg/linux_x64/*",
      "vendor/ffmpeg/linux_amd64/*",
      "vendor/ffmpeg/linux_arm64/*"
    ],
    "useLocalToolsDir": true,
    "linux": {
      "deb": {
        "desktopTemplate": "linux/desktop-template.desktop",
        "files": {
          "/usr/share/applications/com.privacywatermark.codec.desktop": "linux/com.privacywatermark.codec.desktop",
          "/usr/share/icons/hicolor/32x32/apps/com.privacywatermark.codec.png": "icons/32x32.png",
          "/usr/share/icons/hicolor/128x128/apps/com.privacywatermark.codec.png": "icons/128x128.png",
          "/usr/share/icons/hicolor/256x256/apps/com.privacywatermark.codec.png": "icons/256x256.png",
          "/usr/share/icons/hicolor/scalable/apps/com.privacywatermark.codec.svg": "icons/icon.svg",
          "/usr/share/pixmaps/com.privacywatermark.codec.png": "icons/512x512.png",
          "/usr/share/metainfo/com.privacywatermark.codec.metainfo.xml": "linux/com.privacywatermark.codec.metainfo.xml",
          "/usr/share/icons/hicolor/512x512/apps/com.privacywatermark.codec.png": "icons/512x512.png"
        },
        "postInstallScript": "linux/package-postinstall.sh",
        "postRemoveScript": "linux/package-postremove.sh"
      },
      "rpm": {
        "desktopTemplate": "linux/desktop-template.desktop",
        "files": {
          "/usr/share/applications/com.privacywatermark.codec.desktop": "linux/com.privacywatermark.codec.desktop",
          "/usr/share/icons/hicolor/32x32/apps/com.privacywatermark.codec.png": "icons/32x32.png",
          "/usr/share/icons/hicolor/128x128/apps/com.privacywatermark.codec.png": "icons/128x128.png",
          "/usr/share/icons/hicolor/256x256/apps/com.privacywatermark.codec.png": "icons/256x256.png",
          "/usr/share/icons/hicolor/scalable/apps/com.privacywatermark.codec.svg": "icons/icon.svg",
          "/usr/share/pixmaps/com.privacywatermark.codec.png": "icons/512x512.png",
          "/usr/share/metainfo/com.privacywatermark.codec.metainfo.xml": "linux/com.privacywatermark.codec.metainfo.xml",
          "/usr/share/icons/hicolor/512x512/apps/com.privacywatermark.codec.png": "icons/512x512.png"
        },
        "postInstallScript": "linux/package-postinstall.sh",
        "postRemoveScript": "linux/package-postremove.sh"
      },
      "appimage": {
        "bundleMediaFramework": false,
        "files": {
          "/usr/share/icons/hicolor/32x32/apps/com.privacywatermark.codec.png": "icons/32x32.png",
          "/usr/share/icons/hicolor/128x128/apps/com.privacywatermark.codec.png": "icons/128x128.png",
          "/usr/share/icons/hicolor/256x256/apps/com.privacywatermark.codec.png": "icons/256x256.png",
          "/usr/share/icons/hicolor/scalable/apps/com.privacywatermark.codec.svg": "icons/icon.svg",
          "/usr/share/pixmaps/com.privacywatermark.codec.png": "icons/512x512.png",
          "/usr/lib64/.pwc-keep": "linux/appimage-lib64-placeholder",
          "/usr/share/icons/hicolor/512x512/apps/com.privacywatermark.codec.png": "icons/512x512.png"
        }
      }
    }
  },
  "mainBinaryName": "privacy-watermark-codec"
}
